# Easy Music production environment template
# ==========================================
#
# Copy this file to .env.production and fill in every value marked REQUIRED.
# Never commit .env.production or any file containing real secrets to version
# control.
#
# Generating a secret key:
#   openssl rand -hex 32
#
# After editing .env.production, start the stack with:
#   docker compose -f docker-compose.prod.yml --env-file .env.production up -d

# ---------------------------------------------------------------------------
# PostgreSQL  (REQUIRED)
# ---------------------------------------------------------------------------
# Credentials for the production database. Pick a strong password.
POSTGRES_DB=easy_music
POSTGRES_USER=easy_music
POSTGRES_PASSWORD=change-me-production-password

# SQLAlchemy connection string used by the api and worker containers.
# In production the hostname must be "postgres" (the Compose service name).
# The password here must match POSTGRES_PASSWORD.
DATABASE_URL=postgresql+psycopg://easy_music:change-me-production-password@postgres:5432/easy_music

# ---------------------------------------------------------------------------
# Backend application  (REQUIRED)
# ---------------------------------------------------------------------------
# Long random string used to sign JWTs. Generate one with:
#   openssl rand -hex 32
# Never reuse the development default.
APP_SECRET_KEY=change-me-production-secret-key

# Token lifetime in minutes. 1440 = 24 hours. Optional; defaults to 1440.
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Comma-separated list of origins the browser may access from.
# Must include the production HTTPS domain.
# Example: https://music.example.com
CORS_ORIGINS=https://change-me-your-domain.com

# ---------------------------------------------------------------------------
# Domain  (REQUIRED for HTTPS)
# ---------------------------------------------------------------------------
# Public domain name that points to your server. Caddy uses this to obtain
# a Let's Encrypt TLS certificate automatically.
CADDY_DOMAIN=change-me-your-domain.com

# ---------------------------------------------------------------------------
# Media storage  (REQUIRED - set host-side paths before first start)
# ---------------------------------------------------------------------------
# Root directory for media files inside the api / worker containers.
MEDIA_ROOT=/app/media
ORIGINALS_DIR=originals
PLAYBACK_DIR=playback
COVERS_DIR=covers

# Host directories that are bind-mounted into the api and worker containers.
# Recommended layout:
#   /srv/easy-music/media/originals
#   /srv/easy-music/media/playback
#   /srv/easy-music/media/covers
MEDIA_HOST_ORIGINALS=/srv/easy-music/media/originals
MEDIA_HOST_PLAYBACK=/srv/easy-music/media/playback
MEDIA_HOST_COVERS=/srv/easy-music/media/covers

# Maximum upload size in megabytes. Optional; defaults to 200.
MAX_UPLOAD_MB=200

# Maximum uploaded cover image size in megabytes. Optional; defaults to 10.
MAX_COVER_MB=10

# ---------------------------------------------------------------------------
# Logging  (optional)
# ---------------------------------------------------------------------------
# LOG_LEVEL: one of DEBUG, INFO, WARNING, ERROR, CRITICAL (default INFO).
# LOG_FORMAT: "text" (human-readable) or "json" (machine-readable).
LOG_LEVEL=INFO
LOG_FORMAT=text

# ---------------------------------------------------------------------------
# PostgreSQL data directory  (REQUIRED)
# ---------------------------------------------------------------------------
# Host directory where PostgreSQL stores its data files. Must be writable by
# the postgres container user (UID 70 on Alpine).
POSTGRES_DATA_DIR=/srv/easy-music/postgres

# ---------------------------------------------------------------------------
# Media tools  (optional)
# ---------------------------------------------------------------------------
# Paths to ffmpeg / ffprobe inside the container image.
FFMPEG_PATH=ffmpeg
FFPROBE_PATH=ffprobe

# ---------------------------------------------------------------------------
# AI provider  (optional - disabled by default)
# ---------------------------------------------------------------------------
# Set AI_ENABLED=true and fill in your own provider details to enable the
# AI Assistant features. Leave these values as-is to keep AI disabled.
AI_ENABLED=false
AI_PROVIDER=openai-compatible
AI_API_KEY=
AI_MODEL=
AI_BASE_URL=https://api.openai.com/v1

# ---------------------------------------------------------------------------
# Backups  (optional)
# ---------------------------------------------------------------------------
# Number of days to keep database dump files if you later add retention logic.
# The bundled backup script does not delete backup files.
BACKUP_RETENTION_DAYS=30
