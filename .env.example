# Easy Music development environment example
# Copy values into your local environment for development.
# Do not commit real secrets, production passwords, or private host paths.
#
# For production deployment, use .env.production.example instead.
# See docs/TASKS/PHASE_7_TASKS.md and docs/DEPLOYMENT.md.

# PostgreSQL
POSTGRES_DB=easy_music_dev
POSTGRES_USER=easy_music
POSTGRES_PASSWORD=change-me-development-only
DATABASE_URL=postgresql+psycopg://easy_music:change-me-development-only@postgres:5432/easy_music_dev

# Backend application
APP_SECRET_KEY=development-secret-key-change-before-deploy
ACCESS_TOKEN_EXPIRE_MINUTES=1440
CORS_ORIGINS=http://127.0.0.1:3000,http://localhost:3000,http://localhost:5173,http://127.0.0.1:5173

# Media storage
MEDIA_ROOT=/app/media
ORIGINALS_DIR=originals
PLAYBACK_DIR=playback
COVERS_DIR=covers
TEMP_VIDEOS_DIR=temp-videos
MAX_UPLOAD_MB=200
MAX_VIDEO_UPLOAD_MB=1024
MAX_COVER_MB=10

# Import roots (disabled by default)
# Semicolon-separated paths are recommended on Windows because drive letters use ":".
# Use throwaway local directories outside the repository and outside MEDIA_ROOT.
IMPORT_ALLOWED_ROOTS=
IMPORT_SCAN_MAX_FILES=1000
IMPORT_SCAN_MAX_DEPTH=5
IMPORT_SCAN_MAX_FILE_MB=200

# Media tools
FFMPEG_PATH=ffmpeg
FFPROBE_PATH=ffprobe

# AI provider (development-only — no real keys committed)
# Set AI_ENABLED=true and fill in your own provider details for local AI testing.
# Never commit real API keys to this file or any other committed file.
AI_ENABLED=false
AI_PROVIDER=openai-compatible
AI_API_KEY=replace-with-your-own-key
AI_MODEL=replace-with-your-model-id
AI_BASE_URL=https://api.openai.com/v1
